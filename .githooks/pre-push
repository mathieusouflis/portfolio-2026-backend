#!/bin/sh
# Optional pre-push hook — runs before every `git push`.
# Activate with: git config core.hooksPath .githooks
#
# Fast checks only (matches the `lint` job in .github/workflows/ci.yml).
# The full test suite is left to CI since it may need a database once
# sqlx queries land — see docs/product-code/decisions/0002-axum-postgres-sqlx.md.

echo "Checking formatting..."
cargo fmt --all --check || exit 1

echo "Running clippy..."
cargo clippy --workspace --all-targets -- -D warnings || exit 1

# ── Documentation TODOs ─────────────────────────────────────────────────
# Non-blocking: lists template placeholder docs (docs/**/todo_*.md) that
# still need to be filled in, per the domain × type documentation model
# in docs/README.md. Never fails the push — just keeps the remaining work
# visible instead of silently forgotten.
TODO_DOCS=$(find docs -name 'todo_*.md' 2>/dev/null)
if [ -n "$TODO_DOCS" ]; then
  echo ""
  echo "  Documentation still has template placeholders:"
  echo "$TODO_DOCS" | sed 's/^/    - /'
  echo ""
fi

exit 0
